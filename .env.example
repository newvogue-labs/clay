# ── Clay .env.example ──────────────────────────────────────────────
# Copy:  cp .env.example .env
# Fill:  only CLAY_DB_PASSWORD + CLAY_BINANCE_TESTNET_API_KEY/SECRET
# Then:  podman volume create clay_pgdata && podman compose up -d
#        cd backend && uv run alembic upgrade head
#        make backend-run   (terminal 1)
#        make frontend-run  (terminal 2)

# ── Compose (TimescaleDB) ─────────────────────────────────────────
CLAY_DB_PASSWORD=

# ── Database ──────────────────────────────────────────────────────
# Port 5433 = container mapped to host (5432 = live postgres, do not touch)
CLAY_DATABASE_URL=postgresql+psycopg://clay:<password>@localhost:5433/clay

# ── Server ────────────────────────────────────────────────────────
CLAY_SERVER_HOST=127.0.0.1
CLAY_SERVER_PORT=8000

# ── Binance public klines (read-only, no auth) ───────────────────
# If region-blocked → set false + use VPN
CLAY_BINANCE_SPOT_ENABLED=true
CLAY_BINANCE_BASE_URL=https://api.binance.com

# ── Market ingestion ─────────────────────────────────────────────
CLAY_MARKET_SYMBOLS=["BTCUSDT","ETHUSDT","SOLUSDT"]
CLAY_MARKET_TIMEFRAMES=["5m","15m","1h"]
CLAY_MARKET_FETCH_MAX_ATTEMPTS=2
CLAY_MARKET_FETCH_RETRY_DELAY_SECONDS=0.5

# ── Context connectors ───────────────────────────────────────────
CLAY_NEWS_CONNECTOR_IDS=["demo-news"]
CLAY_SENTIMENT_CONNECTOR_IDS=["demo-sentiment"]

# ── Execution (testnet) ──────────────────────────────────────────
CLAY_EXECUTION_MODE=testnet
CLAY_BINANCE_TESTNET_API_KEY=
CLAY_BINANCE_TESTNET_API_SECRET=
CLAY_EXECUTION_MAX_ORDER_NOTIONAL=50

# ── Scheduler (demo defaults) ────────────────────────────────────
CLAY_SCHEDULER_ENABLED=false
CLAY_SCHEDULER_INGESTION_ENABLED=false
CLAY_SCHEDULER_AI_AGENT_ENABLED=false

# ── Frontend ──────────────────────────────────────────────────────
VITE_CLAY_API_BASE_URL=http://127.0.0.1:8000
