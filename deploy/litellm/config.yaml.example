# Копия host-конфига ~/.config/clay/litellm/config.yaml.
# Источник истины — хост. Этот файл — обезличенный reference для деплоя.
#
# LiteLLM gateway — единая точка внешнего egress LLM для Clay (ADR-009).
# Host-native установка, см. runbook-004-litellm-gateway.md
# ВНИМАНИЕ: секретов тут нет и быть не должно. Реальные провайдерские ключи живут
# только в хостовом окружении / бэкапе, в git НИКОГДА не коммитятся.

model_list:
  - model_name: gemma4-e2b
    litellm_params:
      model: ollama/gemma4:e2b-it-qat
      api_base: http://127.0.0.1:11434
  - model_name: local-ollama
    litellm_params:
      model: ollama/deepseek-v4-flash:cloud   # ":cloud" требует подписки ollama.com
      api_base: http://127.0.0.1:11434

litellm_settings:
  drop_params: true
  telemetry: false
# master_key: намеренно не задан — шлюз слушает только 127.0.0.1 (loopback-trust).
